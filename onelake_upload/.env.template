# ─────────────────────────────────────────────────────────────────────────────
# PakMart OneLake Upload Pipeline – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend selection ─────────────────────────────────────────────────────────
# "auto"     → use explorer if the mount exists, otherwise fall back to sdk
# "explorer" → always use the locally-mounted OneLake File Explorer (recommended)
# "sdk"      → always use the Azure SDK over HTTPS (needs credentials below)
UPLOAD_BACKEND=auto

# ── OneLake File Explorer settings (UPLOAD_BACKEND=explorer) ─────────────────
# Root path of the OneLake Explorer mount on your Windows machine.
ONELAKE_EXPLORER_ROOT=C:\Users\Admin\OneLake - Microsoft

# The workspace folder name EXACTLY as it appears in Explorer after syncing.
# → Open  C:\Users\Admin\OneLake - Microsoft  in File Explorer to confirm.
WORKSPACE_FOLDER=pakmart

# The Lakehouse folder name inside that workspace.
# Leave EMPTY to auto-detect the first *.Lakehouse folder found.
LAKEHOUSE_FOLDER=

# Sub-folder inside Files/ where PakMart data will land.
# Results in:  <lakehouse>/Files/pakmart/full/...
REMOTE_FILES_SUBDIR=pakmart

# ── Azure / Fabric credentials (UPLOAD_BACKEND=sdk only) ─────────────────────
# Not needed when UPLOAD_BACKEND=explorer.
AUTH_METHOD=service_principal
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
FABRIC_WORKSPACE_ID=your-workspace-guid-here
FABRIC_LAKEHOUSE_ID=your-lakehouse-guid-here
ONELAKE_ENDPOINT=https://onelake.dfs.fabric.microsoft.com

# ── Local source data ─────────────────────────────────────────────────────────
LOCAL_DATA_ROOT=../pakmart_data

# ── Upload behaviour ──────────────────────────────────────────────────────────
MAX_WORKERS=8
CHUNK_SIZE=4194304
MAX_RETRIES=3
RETRY_BACKOFF=2
SKIP_UNCHANGED=True
